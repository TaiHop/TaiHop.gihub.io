---
const pageTitle = "Tai P. Hopkins";

import BaseLayout from "../layouts/BaseLayout.astro";
import Projects from "../components/Projects.astro";
import AboutMe from "../components/AboutMe.astro";
import SkillsSlider from "../components/SkillsSlider.jsx";
---

<BaseLayout pageTitle={pageTitle}>

    <!-- ABOUT SECTION -->
    <AboutMe>
        Hello! I'm Tai, a passionate programmer with a love for coding and problem-solving. 
        I have experience in various programming languages and enjoy creating innovative 
        solutions to real-world challenges. With a strong background in software development, 
        I am always eager to learn new technologies and expand my skill set. I thrive in 
        collaborative environments and am dedicated to delivering high-quality work.
    </AboutMe>

    <!-- SKILLS (NOW USING SLIDER COMPONENT) -->
    <SkillsSlider client:load />

    <!-- PROJECTS -->
    <section id="projects" class="projects-section">
        <h2>Projects</h2>
        <Projects />
    </section>

</BaseLayout>

